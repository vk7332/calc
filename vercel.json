{
    "version": 2,
    "builds": [
        {
            "src": "vite.config.ts",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "env": {
        "VITE_SUPABASE_URL": "",
        "VITE_SUPABASE_ANON_KEY": "",
        "VITE_OPENAI_API_KEY": ""
    }
}